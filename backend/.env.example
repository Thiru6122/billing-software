# Copy this file to .env before first run (install script does this automatically)

# Local MongoDB on the shop PC (recommended for daily billing)
DATABASE="mongodb://localhost:27017/saltum"

# Change this to a long random string before going live
JWT_SECRET="change-this-to-a-long-random-secret-key"

NODE_ENV=production
SERVE_FRONTEND=true

# Used for PDF download links
PUBLIC_SERVER_FILE="http://localhost:8888/"

# Optional – email for license OTP (use Resend OR Gmail SMTP)
#RESEND_API=re_xxxxxxxx
#LICENSE_EMAIL_FROM=Saltum <billing@yourdomain.com>

# Gmail SMTP example (use App Password from Google Account → Security)
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USER=thiru6122@gmail.com
#SMTP_PASS=your-16-char-app-password
#SMTP_FROM=Saltum Billing <thiru6122@gmail.com>

# Monthly license lock (disable billing if customer has not paid)
LICENSE_ENABLED=true
# Days of each month when the system is locked (comma-separated)
LICENSE_LOCK_DAYS=1,2
# OTP for unlock is sent to this email (Saltum vendor)
LICENSOR_EMAIL=thiru6122@gmail.com

#OPENAI_API_KEY=
