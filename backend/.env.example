# Copy this file to .env before first run (install script does this automatically)

# Local MongoDB on the shop PC (recommended for daily billing)
DATABASE="mongodb://localhost:27017/saltum"

# Change this to a long random string before going live
JWT_SECRET="change-this-to-a-long-random-secret-key"

NODE_ENV=production
SERVE_FRONTEND=true

# Used for PDF download links
PUBLIC_SERVER_FILE="http://localhost:8888/"

# Optional – email sending (not required for basic billing)
#RESEND_API=
#OPENAI_API_KEY=
