doctype html
html(class='paper-a4')
  head
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    include _invoicePrintStyles
  body
    include _ashwinDocument
    -
      var lead = model.lead || {};
      var offerParty = {
        name: lead.name || '—',
        address: lead.address || '',
        phone: lead.phone || '',
        gstin: lead.gstin || ''
      };
    +ashwinDocument({
      docTitle: 'OFFER',
      party: offerParty,
      partyLabel: 'To :',
      metaRows: [
        { label: 'Offer No', value: model.number + '/' + (model.year || '') },
        { label: 'Date', value: moment(model.date).format('DD/MM/YYYY') },
        { label: 'Valid Until', value: moment(model.expiredDate).format('DD/MM/YYYY') },
        { label: 'Ref No', value: (model.createdBy && (model.createdBy.name || model.createdBy.email)) || '-' }
      ],
      showGstColumn: false
    })
