mixin ashwinDocument(options)
  -
    var docTitle = options.docTitle || 'TAX INVOICE';
    var party = options.party || {};
    var partyLabel = options.partyLabel || 'To :';
    var metaRows = options.metaRows || [];
    var items = options.items || model.items || [];
    var totalQty = items.reduce(function (sum, item) {
      return sum + (Number(item.quantity) || 0);
    }, 0);
    var summaryRows = options.taxSummary || taxSummary || [];
    if (!summaryRows.length && model.taxTotal > 0) {
      var docRate = Number(model.taxRate) || 0;
      summaryRows = [{
        rate: docRate,
        taxable: model.subTotal || 0,
        gst: model.taxTotal,
        total: model.total || 0,
      }];
    }
    var showGstColumn = options.showGstColumn !== false;
    var showBankDetails = options.showBankDetails !== false;
    var showFooter = options.showFooter !== false;
    var footerNote = options.footerNote || '';
    var refNo = options.refNo
      || (model.createdBy && (model.createdBy.name || model.createdBy.email))
      || '-';
    var gstType = model.gstType || 'intra';
    var companyGstin = settings.company_gstin || settings.company_tax_number || '-';
    var bankName = settings.company_bank_name || '';
    var bankAccount = settings.company_bank_account_number || settings.company_bank_account || '';
    var bankIfsc = settings.company_bank_ifsc || '';
    var bankBranch = settings.company_bank_branch || '';
    var bankGpay = settings.company_gpay || '9710660508';
    var companyPhone = settings.company_phone || '';
    if (settings.company_email && companyPhone) {
      companyPhone += ', ' + settings.company_email;
    } else if (settings.company_email) {
      companyPhone = settings.company_email;
    }
    var grossAmount = options.grossAmount != null
      ? options.grossAmount
      : (model.subTotal != null ? model.subTotal : (model.total != null ? model.total : model.amount));
    var netAmount = options.netAmount != null
      ? options.netAmount
      : (model.total != null ? model.total : (model.amount != null ? model.amount : 0));
    var itemRowHeight = options.itemRowHeight != null ? options.itemRowHeight : 12;
    var minTableRows = options.minTableRows != null ? options.minTableRows : 15;
    var blankRowsNeeded = minTableRows > 0
      ? (items.length ? Math.max(0, minTableRows - items.length) : minTableRows)
      : 0;
    var maxBlankRows = !items.length ? 6 : items.length <= 2 ? 4 : items.length <= 5 ? 6 : 0;
    var blankRowCount = minTableRows > 0 && items.length < 8
      ? Math.min(blankRowsNeeded, maxBlankRows)
      : 0;
    var blankFillHeight = blankRowCount * itemRowHeight;

  .invoice-box(class=options.compactLayout ? 'compact-layout' : '')
    .doc-title= docTitle

    .company-header
      .name= settings.company_name || 'Company Name'
      if settings.company_address
        each line in settings.company_address.split(/\r?\n/)
          if line.trim()
            .address= line.trim()
      if companyPhone
        .contact PH: #{companyPhone}
      .gst GST NO: #{companyGstin}

    .billing-row
      .col
        div
          span.label #{partyLabel}
          |  #{party.name || '—'}
        -
          var addressText = party.address ? String(party.address).trim() : '';
          var addressLines = addressText
            ? (/\r?\n/.test(addressText)
              ? addressText.split(/\r?\n/)
              : addressText.split(/,\s*/))
            : [];
        if addressLines.length
          each line in addressLines
            if line.trim()
              div= line.trim()
        else if party.state
          div= party.state
        if party.phone
          div PH: #{party.phone}
        if party.gstin
          div= party.gstin
      .col
        table.meta-table
          each row in metaRows
            tr
              td.label= row.label
              td : #{row.value}
          if metaRows.length === 0
            tr
              td.label Bill No
              td : #{model.number}/#{model.year || ''}
            tr
              td.label Date
              td : #{moment(model.date).format('DD/MM/YYYY')}
            tr
              td.label Ref No
              td : #{refNo}

    table.items-table(class=!items.length ? 'no-lines' : '')
      thead
        tr
          th.col-sno S.No
          th.col-hsn HSN
          th.col-items Items
          th.col-qty Qty
          th.col-rate Rate
          if showGstColumn
            th.col-gst Gst%
          th.col-amount Amount
      tbody
        each item, index in items
          tr.item-row
            td.col-sno= index + 1
            td.col-hsn= (item.hsnCode || '').toString().replace(/\s+/g, '')
            td.col-items
              | #{item.itemName}
              if item.description && !/^\s*SKU\s*:/i.test(item.description)
                span.desc-sub= item.description
            td.col-qty= item.quantity
            td.col-rate= indianAmount(item.price)
            if showGstColumn
              td.col-gst= item.gstRate ? item.gstRate : (model.taxRate || '')
            td.col-amount= indianAmount(item.total)
        if blankFillHeight > 0
          tr.blank-row.blank-row-fill(style=`height: ${blankFillHeight}px`)
            td.col-sno
            td.col-hsn
            td.col-items
            td.col-qty
            td.col-rate
            if showGstColumn
              td.col-gst
            td.col-amount

    .invoice-bottom
      .summary-row
        .left
          .tot-qty Tot.Qty : #{totalQty}
          if summaryRows.length
            table.tax-table
              thead
                tr
                  th SGST %
                  th AMT
                  th CGST %
                  th AMT
                  th Goods
              tbody
                each row in summaryRows
                  if gstType === 'inter'
                    tr
                      td= row.rate
                      td= indianAmount(row.gst)
                      td -
                      td -
                      td= indianAmount(row.taxable)
                  else
                    tr
                      td= (row.rate / 2).toFixed(2)
                      td= indianAmount(row.gst / 2)
                      td= (row.rate / 2).toFixed(2)
                      td= indianAmount(row.gst / 2)
                      td= indianAmount(row.taxable)
        .right
          .amount-box
            .line
              span Gross Amt :
              span= indianAmount(grossAmount)
            .line.net
              span Net Amount :
              span= indianAmount(netAmount)

      if amountInWords
        .amount-words
          span.label Amount in Words :
          span= amountInWords(netAmount)

      if showFooter
        .footer-row(class=!showBankDetails ? 'no-bank' : '')
          .col
            if showBankDetails
              .bank-title BANK DETAILS:
              if bankName || bankAccount
                div BANK NAME: #{bankName} A\C NO: #{bankAccount}
              if bankIfsc
                div IFSC CODE: #{bankIfsc}
              if bankBranch
                div (#{bankBranch})
              if bankGpay
                div G PAY NO: #{bankGpay}
              if !bankName && !bankAccount && !bankIfsc && !bankGpay
                div Add bank details in Company Settings
            if footerNote
              .footer-note= footerNote
            .signature-left Customer Signature and Seal
          .col.signature-right
            .for-company For #{settings.company_name || 'Company Name'}
            .signatory Authorised Signatory