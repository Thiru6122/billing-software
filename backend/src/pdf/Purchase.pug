doctype html
html(class='paper-a4')
  head
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    include _invoicePrintStyles
  body
    include _ashwinDocument
    +ashwinDocument({
      docTitle: 'PURCHASE ORDER',
      party: supplier,
      partyLabel: 'From :',
      metaRows: [
        { label: 'PO No', value: model.number + '/' + (model.year || '') },
        { label: 'Date', value: moment(model.date).format('DD/MM/YYYY') },
        { label: 'Ref No', value: (model.createdBy && (model.createdBy.name || model.createdBy.email)) || '-' }
      ],
      showGstColumn: true
    })
