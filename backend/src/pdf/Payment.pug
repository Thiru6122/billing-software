doctype html
html(class='paper-a4')
  head
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    include _invoicePrintStyles
  body
    include _ashwinDocument
    -
      var paymentClient = model.client || {};
      var paymentParty = {
        name: paymentClient.name || '—',
        address: paymentClient.address || '',
        phone: paymentClient.phone || '',
        gstin: paymentClient.gstin || ''
      };
      var paymentItems = [{
        itemName: 'Payment Received',
        quantity: 1,
        price: model.amount,
        total: model.amount
      }];
    +ashwinDocument({
      docTitle: 'PAYMENT RECEIPT',
      party: paymentParty,
      partyLabel: 'To :',
      items: paymentItems,
      metaRows: [
        { label: 'Receipt No', value: String(model.number) + (model.year ? '/' + model.year : '') },
        { label: 'Date', value: moment(model.date).format('DD/MM/YYYY') },
        { label: 'Ref No', value: model.ref || (model.createdBy && (model.createdBy.name || model.createdBy.email)) || '-' }
      ],
      showGstColumn: false,
      minTableRows: 1
    })
