style.
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Times New Roman', Times, serif;
    font-size: 10pt;
    line-height: 1.15;
    color: #000;
    background: #fff;
  }

  html.paper-a6 body {
    font-size: 9.5pt;
    line-height: 1.12;
    padding-top: 2mm;
  }

  html.paper-a6 .proforma-estimate {
    padding-top: 1mm;
  }

  .proforma-estimate {
    width: 100%;
  }

  .doc-title {
    text-align: center;
    font-weight: 400;
    font-size: 9.5pt;
    padding: 1px 4px 2px;
  }

  html.paper-a6 .doc-title {
    font-size: 9.5pt;
    padding: 2px 4px 2px;
    line-height: 1.2;
  }

  .company-header {
    text-align: center;
    padding: 0 4px 3px;
  }

  html.paper-a6 .company-header {
    padding: 0 4px 2px;
  }

  .company-header .name {
    font-size: 13pt;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1px;
  }

  html.paper-a6 .company-header .name {
    font-size: 12.5pt;
  }

  .company-header .line {
    font-size: 8.5pt;
    line-height: 1.1;
  }

  html.paper-a6 .company-header .line {
    font-size: 8.5pt;
    line-height: 1.08;
  }

  .company-header .company-address {
    padding: 0 2px;
  }

  .company-header .contact-line .sep {
    margin: 0 3px;
  }

  .rule {
    border: 0;
    border-top: 1px solid #000;
    margin: 0;
  }

  .party-section {
    padding: 2px 6px 3px;
    font-size: 8.5pt;
    line-height: 1.1;
  }

  html.paper-a6 .party-section {
    padding: 2px 6px 3px;
    font-size: 8.5pt;
  }

  .party-section .party-line {
    margin: 0;
  }

  .party-section .party-line + .party-line {
    margin-top: 1px;
  }

  .party-section .label,
  .party-section .party-line:first-child .label {
    font-weight: 700;
  }

  .party-section .party-address {
    word-wrap: break-word;
  }

  .meta-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 2px 6px 3px;
    font-size: 9pt;
    font-weight: 700;
    line-height: 1.1;
  }

  html.paper-a6 .meta-row {
    padding: 2px 6px 3px;
    font-size: 9pt;
  }

  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .items-table thead th {
    border-top: 1px solid #000;
    border-bottom: 1px solid #000;
    border-left: 1px solid #000;
    padding: 2px 3px;
    font-size: 9pt;
    font-weight: 700;
    text-align: center;
    vertical-align: middle;
    line-height: 1.1;
  }

  html.paper-a6 .items-table thead th {
    font-size: 9pt;
    padding: 2px 3px;
  }

  .items-table thead th:last-child { border-right: 1px solid #000; }

  .items-table tbody td {
    border-left: 1px solid #000;
    padding: 1px 3px;
    font-size: 9pt;
    vertical-align: top;
    line-height: 1.12;
  }

  html.paper-a6 .items-table tbody td {
    font-size: 9pt;
    padding: 1px 3px;
  }

  .items-table tbody td:last-child { border-right: 1px solid #000; }

  .items-table tbody tr:last-child td {
    border-bottom: 1px solid #000;
  }

  .items-table .col-sno { width: 8%; text-align: center; }
  .items-table .col-items { width: 44%; text-align: left; }
  .items-table .col-qty { width: 12%; text-align: center; }
  .items-table .col-rate { width: 18%; text-align: center; }
  .items-table .col-amount { width: 18%; text-align: center; }

  .items-table tbody tr.blank-row td {
    height: 12px;
    padding: 0 3px;
    line-height: 1;
  }

  .net-total {
    text-align: right;
    padding: 4px 6px 2px;
    font-size: 10pt;
    font-weight: 700;
    line-height: 1.1;
  }

  html.paper-a6 .net-total {
    padding: 4px 6px 2px;
    font-size: 10pt;
  }

  @media print {
    html.paper-a6 body {
      padding-top: 2mm;
    }

    html.paper-a6 .proforma-estimate {
      padding-top: 1mm;
    }

    .proforma-estimate {
      page-break-inside: auto;
    }

    .items-table tbody tr.item-row {
      page-break-inside: avoid;
    }
  }
