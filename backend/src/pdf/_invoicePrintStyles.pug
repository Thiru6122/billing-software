style.
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Courier New', Courier, monospace;
    font-size: 11pt;
    line-height: 1.18;
    color: #000;
    background: #fff;
  }

  html.paper-a5 body { font-size: 10pt; }
  html.paper-a4 body { font-size: 11.5pt; }

  .invoice-box {
    width: 100%;
    border: 1px solid #000;
  }

  .doc-title {
    text-align: left;
    font-weight: 700;
    font-size: 13pt;
    letter-spacing: 0.6px;
    padding: 3px 8px 1px;
  }

  html.paper-a4 .doc-title {
    font-size: 14pt;
    padding: 4px 10px 2px;
  }

  .company-header {
    text-align: center;
    padding: 1px 8px 4px;
    border-bottom: 1px solid #000;
  }

  html.paper-a4 .company-header { padding: 2px 10px 5px; }

  .company-header .name {
    font-size: 15pt;
    font-weight: 700;
    margin-bottom: 0;
  }

  html.paper-a4 .company-header .name {
    font-size: 17pt;
    margin-bottom: 1px;
  }

  .company-header .address,
  .company-header .contact,
  .company-header .gst {
    font-size: 10.5pt;
    line-height: 1.15;
  }

  html.paper-a4 .company-header .address,
  html.paper-a4 .company-header .contact,
  html.paper-a4 .company-header .gst {
    font-size: 11.5pt;
  }

  .billing-row {
    display: table;
    width: 100%;
    border-bottom: 1px solid #000;
  }

  .billing-row .col {
    display: table-cell;
    width: 50%;
    vertical-align: top;
    padding: 3px 8px;
    font-size: 10.5pt;
    line-height: 1.15;
  }

  html.paper-a4 .billing-row .col {
    padding: 4px 10px;
    font-size: 11.5pt;
  }

  .billing-row .col:first-child { border-right: 1px solid #000; }
  .billing-row .label { font-weight: 700; }

  .meta-table {
    width: 100%;
    border-collapse: collapse;
  }

  .meta-table td {
    padding: 0;
    vertical-align: top;
    line-height: 1.15;
  }

  .meta-table .label {
    font-weight: 700;
    white-space: nowrap;
    padding-right: 4px;
  }

  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .items-table thead {
    display: table-header-group;
  }

  .items-table thead th {
    border: 1px solid #000;
    padding: 2px 2px;
    font-size: 9.5pt;
    vertical-align: middle;
    font-weight: 700;
    text-align: center;
    white-space: nowrap;
    line-height: 1.1;
  }

  html.paper-a4 .items-table thead th {
    padding: 2px 3px;
    font-size: 10.5pt;
  }

  .items-table tbody tr.item-row td,
  .items-table tbody tr.blank-row-fill td {
    border-top: none;
    border-bottom: none;
    border-left: 1px solid #000;
    border-right: none;
    padding: 0 2px;
    font-size: 10pt;
    vertical-align: top;
    line-height: 1.15;
  }

  html.paper-a4 .items-table tbody tr.item-row td,
  html.paper-a4 .items-table tbody tr.blank-row-fill td {
    padding: 0 3px;
    font-size: 11pt;
  }

  .items-table tbody tr.item-row td:last-child,
  .items-table tbody tr.blank-row-fill td:last-child {
    border-right: 1px solid #000;
  }

  .items-table tbody tr.blank-row-fill td {
    padding: 0;
    line-height: 1;
  }

  .items-table .col-sno { width: 5%; text-align: center; }

  .items-table .col-hsn {
    width: 12%;
    text-align: center;
    white-space: nowrap;
    word-wrap: normal;
    overflow-wrap: normal;
    font-size: 9pt;
    line-height: 1.15;
  }

  html.paper-a4 .items-table .col-hsn { font-size: 10pt; }

  .items-table .col-items {
    width: 32%;
    text-align: left;
    white-space: normal;
    word-wrap: break-word;
  }

  .items-table .col-qty { width: 7%; text-align: right; }
  .items-table .col-rate { width: 11%; text-align: right; }
  .items-table .col-gst { width: 7%; text-align: right; white-space: nowrap; }
  .items-table .col-amount { width: 14%; text-align: right; white-space: nowrap; }

  .items-table .desc-sub {
    display: block;
    font-size: 8.5pt;
    margin-top: 0;
    line-height: 1.1;
  }

  html.paper-a4 .items-table .desc-sub { font-size: 9pt; }

  .items-table.no-lines th,
  .items-table.no-lines tbody td {
    border: none;
  }

  .items-table.no-lines thead th {
    border-bottom: 1px solid #000;
  }

  .invoice-bottom {
    page-break-inside: avoid;
  }

  .summary-row {
    display: table;
    width: 100%;
    border-top: 1px solid #000;
    page-break-inside: avoid;
  }

  .summary-row .left,
  .summary-row .right {
    display: table-cell;
    vertical-align: top;
    padding: 3px 8px;
    font-size: 10.5pt;
    line-height: 1.15;
  }

  html.paper-a4 .summary-row .left,
  html.paper-a4 .summary-row .right {
    padding: 4px 10px;
    font-size: 11.5pt;
  }

  .summary-row .left {
    width: 58%;
    border-right: 1px solid #000;
  }

  .summary-row .right { width: 42%; }

  .tot-qty {
    margin-bottom: 3px;
    font-weight: 700;
  }

  .tax-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 9.5pt;
  }

  html.paper-a4 .tax-table { font-size: 10.5pt; }

  .tax-table th,
  .tax-table td {
    border: 1px solid #000;
    padding: 1px 3px;
    text-align: right;
  }

  html.paper-a4 .tax-table th,
  html.paper-a4 .tax-table td { padding: 2px 4px; }

  .tax-table th:first-child,
  .tax-table td:first-child { text-align: center; }

  .amount-box {
    border: 1px solid #000;
    padding: 4px 8px;
  }

  html.paper-a4 .amount-box { padding: 5px 10px; }

  .amount-box .line {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    white-space: nowrap;
    gap: 8px;
    margin-bottom: 2px;
  }

  .amount-box .line:last-child { margin-bottom: 0; }

  .amount-box .line span:last-child {
    text-align: right;
    flex-shrink: 0;
  }

  .amount-box .line.net {
    font-weight: 700;
    font-size: 12pt;
  }

  html.paper-a4 .amount-box .net { font-size: 13pt; }

  .footer-row {
    display: table;
    width: 100%;
    border-top: 1px solid #000;
    min-height: 60px;
    page-break-inside: avoid;
  }

  html.paper-a4 .footer-row { min-height: 68px; }

  .footer-row .col {
    display: table-cell;
    width: 50%;
    vertical-align: top;
    padding: 4px 8px;
    font-size: 10.5pt;
    line-height: 1.15;
  }

  html.paper-a4 .footer-row .col {
    padding: 5px 10px;
    font-size: 11.5pt;
  }

  .footer-row .col:first-child { border-right: 1px solid #000; }

  .bank-title {
    font-weight: 700;
    text-decoration: underline;
    margin-bottom: 2px;
  }

  .footer-note {
    margin-top: 3px;
    font-size: 9.5pt;
    font-style: italic;
  }

  .signature-left {
    margin-top: 10px;
    font-size: 10pt;
  }

  html.paper-a4 .signature-left {
    margin-top: 14px;
    font-size: 11pt;
  }

  .signature-right {
    text-align: right;
    height: 100%;
  }

  .signature-right .for-company {
    font-weight: 700;
    margin-bottom: 16px;
  }

  html.paper-a4 .signature-right .for-company { margin-bottom: 20px; }

  .signature-right .signatory { font-size: 10pt; }
  html.paper-a4 .signature-right .signatory { font-size: 11pt; }

  @media print {
    .invoice-box {
      page-break-inside: auto;
    }

    .items-table thead {
      display: table-header-group;
    }

    .items-table tbody tr.item-row {
      page-break-inside: avoid;
    }

    .items-table tbody tr.blank-row-fill {
      page-break-inside: avoid;
    }
  }
