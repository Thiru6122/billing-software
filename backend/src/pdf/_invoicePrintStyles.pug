style.
  * { box-sizing: border-box; }
  body {
    margin: 0;
    padding: 0;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 9.5pt;
    line-height: 1.28;
    color: #111;
    background: #fff;
  }
  html.paper-a5 body { font-size: 10pt; line-height: 1.32; }
  html.paper-a4 body { font-size: 10.5pt; line-height: 1.32; }
  .invoice-box {
    width: 100%;
    border: 1px solid #111;
  }
  .top-bar {
    display: table;
    width: 100%;
    border-bottom: 1px solid #111;
  }
  .top-bar > div {
    display: table-cell;
    padding: 2px 5px;
    vertical-align: middle;
    font-size: 8.5pt;
  }
  html.paper-a4 .top-bar > div { padding: 3px 6px; font-size: 9pt; }
  html.paper-a5 .top-bar .center { font-size: 11pt; }
  .top-bar .center {
    text-align: center;
    font-weight: 700;
    font-size: 10.5pt;
  }
  html.paper-a4 .top-bar .center { font-size: 11.5pt; }
  .top-bar .right { text-align: right; }
  .company-header {
    display: table;
    width: 100%;
    border-bottom: 1px solid #111;
  }
  .company-header .logo-cell {
    display: table-cell;
    width: 52px;
    padding: 3px 4px;
    vertical-align: middle;
    border-right: 1px solid #111;
  }
  html.paper-a4 .company-header .logo-cell { width: 62px; padding: 4px 5px; }
  .company-header .logo-cell img {
    max-width: 46px;
    max-height: 46px;
    object-fit: contain;
  }
  html.paper-a4 .company-header .logo-cell img { max-width: 54px; max-height: 54px; }
  .company-header .info-cell {
    display: table-cell;
    padding: 3px 6px;
    vertical-align: middle;
    text-align: center;
  }
  html.paper-a4 .company-header .info-cell { padding: 4px 8px; }
  .company-header .info-cell .name {
    font-size: 11pt;
    font-weight: 700;
    margin-bottom: 1px;
  }
  html.paper-a4 .company-header .info-cell .name { font-size: 12.5pt; margin-bottom: 2px; }
  .company-header .info-cell .meta {
    font-size: 8pt;
    line-height: 1.3;
  }
  html.paper-a4 .company-header .info-cell .meta { font-size: 8.5pt; }
  .two-col {
    display: table;
    width: 100%;
    border-bottom: 1px solid #111;
  }
  .two-col .col {
    display: table-cell;
    width: 50%;
    vertical-align: top;
    padding: 0;
  }
  .two-col .col:first-child { border-right: 1px solid #111; }
  .section-title {
    font-weight: 700;
    padding: 2px 5px;
    border-bottom: 1px solid #111;
    background: #fafafa;
    font-size: 8.5pt;
  }
  html.paper-a4 .section-title { padding: 3px 6px; font-size: 9pt; }
  .field-grid {
    width: 100%;
    border-collapse: collapse;
  }
  .field-grid td {
    padding: 1px 5px;
    vertical-align: top;
    border-bottom: 1px solid #ddd;
    font-size: 8.5pt;
  }
  html.paper-a4 .field-grid td { padding: 2px 6px; font-size: 9pt; }
  .field-grid tr:last-child td { border-bottom: none; }
  .field-grid .label {
    width: 42%;
    font-weight: 600;
    white-space: nowrap;
  }
  .bank-qr-row {
    display: table;
    width: 100%;
  }
  .bank-qr-row .bank-details {
    display: table-cell;
    vertical-align: top;
    width: 65%;
    padding-right: 4px;
  }
  .bank-qr-row .e-invoice-qr {
    display: table-cell;
    vertical-align: middle;
    width: 35%;
    text-align: center;
    padding-left: 2px;
  }
  .bank-qr-row .e-invoice-qr img {
    width: 50px;
    height: 50px;
    display: block;
    margin: 0 auto 1px;
  }
  html.paper-a4 .bank-qr-row .e-invoice-qr img { width: 58px; height: 58px; }
  .bank-qr-row .e-invoice-qr .qr-label {
    font-size: 7pt;
    font-weight: 600;
  }
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .items-table th,
  .items-table td {
    border: 1px solid #111;
    padding: 2px 3px;
    font-size: 8.5pt;
    vertical-align: top;
    word-wrap: break-word;
  }
  html.paper-a4 .items-table th,
  html.paper-a4 .items-table td { padding: 3px 4px; font-size: 9pt; }
  html.paper-a5 .items-table th,
  html.paper-a5 .items-table td { font-size: 9pt; }
  .items-table th {
    background: #f5f5f5;
    font-weight: 700;
    text-align: center;
  }
  .items-table td.num { text-align: right; white-space: nowrap; }
  .items-table td.center { text-align: center; }
  .items-table td.left { text-align: left; }
  .items-table .desc-sub {
    display: block;
    color: #555;
    font-size: 7.5pt;
    margin-top: 1px;
  }
  html.paper-a4 .items-table .desc-sub { font-size: 8pt; }
  .summary-row td {
    font-weight: 700;
    background: #fafafa;
  }
  .amount-words {
    padding: 3px 5px;
    border-top: 1px solid #111;
    border-bottom: 1px solid #111;
    font-size: 8.5pt;
  }
  html.paper-a4 .amount-words { padding: 4px 6px; font-size: 9pt; }
  .payment-summary {
    display: table;
    width: 100%;
    border-bottom: 1px solid #111;
  }
  .payment-summary .left,
  .payment-summary .right {
    display: table-cell;
    vertical-align: top;
    padding: 3px 5px;
    font-size: 8.5pt;
  }
  html.paper-a4 .payment-summary .left,
  html.paper-a4 .payment-summary .right { padding: 4px 6px; font-size: 9pt; }
  .payment-summary .left { width: 55%; border-right: 1px solid #111; }
  .tax-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 2px;
    font-size: 8pt;
  }
  html.paper-a4 .tax-table { font-size: 8.5pt; }
  .tax-table th,
  .tax-table td {
    border: 1px solid #ccc;
    padding: 1px 3px;
    text-align: right;
  }
  html.paper-a4 .tax-table th,
  html.paper-a4 .tax-table td { padding: 2px 4px; }
  .tax-table th:first-child,
  .tax-table td:first-child { text-align: left; }
  .footer-grid {
    display: table;
    width: 100%;
  }
  .footer-grid .col {
    display: table-cell;
    width: 33.33%;
    vertical-align: top;
    border-right: 1px solid #111;
    padding: 4px 5px;
  }
  html.paper-a4 .footer-grid .col { padding: 5px 6px; }
  .footer-grid .col:last-child { border-right: none; }
  .footer-grid .col-title {
    font-weight: 700;
    margin-bottom: 3px;
    font-size: 8.5pt;
  }
  html.paper-a4 .footer-grid .col-title { margin-bottom: 4px; font-size: 9pt; }
  .terms-list {
    margin: 0;
    padding-left: 12px;
    font-size: 7.5pt;
    line-height: 1.3;
  }
  html.paper-a4 .terms-list { font-size: 8pt; line-height: 1.35; }
  .bank-table td {
    padding: 1px 0;
    font-size: 8pt;
  }
  html.paper-a4 .bank-table td { font-size: 8.5pt; }
  .bank-table .label { font-weight: 600; width: 38%; }
  .signature-box {
    text-align: right;
    padding-top: 6px;
    font-size: 8.5pt;
  }
  html.paper-a4 .signature-box { padding-top: 10px; font-size: 9pt; }
  .signature-line {
    margin-top: 14px;
    border-top: 1px solid #111;
    display: inline-block;
    min-width: 100px;
    text-align: center;
    padding-top: 2px;
  }
  html.paper-a4 .signature-line { margin-top: 20px; min-width: 120px; }
  .page-footer {
    text-align: center;
    font-size: 7pt;
    color: #666;
    padding: 3px;
    border-top: 1px solid #111;
  }
  html.paper-a4 .page-footer { font-size: 7.5pt; padding: 4px; }
  .dash { color: #888; }
