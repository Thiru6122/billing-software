doctype html
html
  head
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    style.
      * { box-sizing: border-box; }
      body {
        margin: 0;
        padding: 0;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 11px;
        line-height: 1.35;
        color: #111;
        background: #fff;
      }
      .invoice-box {
        width: 100%;
        border: 1px solid #111;
      }
      .top-bar {
        display: table;
        width: 100%;
        border-bottom: 1px solid #111;
      }
      .top-bar > div {
        display: table-cell;
        padding: 4px 8px;
        vertical-align: middle;
      }
      .top-bar .center {
        text-align: center;
        font-weight: 700;
        font-size: 13px;
      }
      .top-bar .right { text-align: right; }
      .company-header {
        display: table;
        width: 100%;
        border-bottom: 1px solid #111;
      }
      .company-header .logo-cell {
        display: table-cell;
        width: 90px;
        padding: 8px;
        vertical-align: middle;
        border-right: 1px solid #111;
      }
      .company-header .logo-cell img {
        max-width: 72px;
        max-height: 72px;
        object-fit: contain;
      }
      .company-header .info-cell {
        display: table-cell;
        padding: 8px 10px;
        vertical-align: middle;
        text-align: center;
      }
      .company-header .info-cell .name {
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 4px;
      }
      .company-header .info-cell .meta {
        font-size: 10px;
        line-height: 1.45;
      }
      .two-col {
        display: table;
        width: 100%;
        border-bottom: 1px solid #111;
      }
      .two-col .col {
        display: table-cell;
        width: 50%;
        vertical-align: top;
        padding: 0;
      }
      .two-col .col:first-child { border-right: 1px solid #111; }
      .section-title {
        font-weight: 700;
        padding: 4px 8px;
        border-bottom: 1px solid #111;
        background: #fafafa;
      }
      .field-grid {
        width: 100%;
        border-collapse: collapse;
      }
      .field-grid td {
        padding: 3px 8px;
        vertical-align: top;
        border-bottom: 1px solid #ddd;
      }
      .field-grid tr:last-child td { border-bottom: none; }
      .field-grid .label {
        width: 42%;
        font-weight: 600;
        white-space: nowrap;
      }
      .e-invoice-bar {
        display: table;
        width: 100%;
        border-bottom: 1px solid #111;
        font-size: 10px;
      }
      .e-invoice-bar > div {
        display: table-cell;
        padding: 4px 8px;
        border-right: 1px solid #111;
      }
      .e-invoice-bar > div:last-child { border-right: none; }
      .items-table {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
      }
      .items-table th,
      .items-table td {
        border: 1px solid #111;
        padding: 4px 5px;
        font-size: 10px;
        vertical-align: top;
      }
      .items-table th {
        background: #f5f5f5;
        font-weight: 700;
        text-align: center;
      }
      .items-table td.num { text-align: right; white-space: nowrap; }
      .items-table td.center { text-align: center; }
      .items-table td.left { text-align: left; }
      .items-table .desc-sub {
        display: block;
        color: #555;
        font-size: 9px;
        margin-top: 2px;
      }
      .summary-row td {
        font-weight: 700;
        background: #fafafa;
      }
      .amount-words {
        padding: 6px 8px;
        border-top: 1px solid #111;
        border-bottom: 1px solid #111;
        font-size: 10px;
      }
      .payment-summary {
        display: table;
        width: 100%;
        border-bottom: 1px solid #111;
      }
      .payment-summary .left,
      .payment-summary .right {
        display: table-cell;
        vertical-align: top;
        padding: 6px 8px;
      }
      .payment-summary .left { width: 55%; border-right: 1px solid #111; }
      .tax-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 4px;
        font-size: 10px;
      }
      .tax-table th,
      .tax-table td {
        border: 1px solid #ccc;
        padding: 3px 5px;
        text-align: right;
      }
      .tax-table th:first-child,
      .tax-table td:first-child { text-align: left; }
      .footer-grid {
        display: table;
        width: 100%;
      }
      .footer-grid .col {
        display: table-cell;
        width: 33.33%;
        vertical-align: top;
        border-right: 1px solid #111;
        padding: 8px;
        min-height: 120px;
      }
      .footer-grid .col:last-child { border-right: none; }
      .footer-grid .col-title {
        font-weight: 700;
        margin-bottom: 6px;
        font-size: 10px;
      }
      .terms-list {
        margin: 0;
        padding-left: 14px;
        font-size: 9px;
        line-height: 1.45;
      }
      .bank-table td {
        padding: 2px 0;
        font-size: 10px;
      }
      .bank-table .label { font-weight: 600; width: 38%; }
      .signature-box {
        text-align: right;
        padding-top: 24px;
        font-size: 10px;
      }
      .signature-line {
        margin-top: 36px;
        border-top: 1px solid #111;
        display: inline-block;
        min-width: 140px;
        text-align: center;
        padding-top: 4px;
      }
      .page-footer {
        text-align: center;
        font-size: 9px;
        color: #666;
        padding: 6px;
        border-top: 1px solid #111;
      }
      .dash { color: #888; }
  body
    .invoice-box
      .top-bar
        div Page No. 1 of 1
        div.center TAX INVOICE
        div.right Original Copy

      .company-header
        .logo-cell
          if settings.company_logo
            img(src=settings.public_server_file + settings.company_logo alt='Logo')
        .info-cell
          .name= settings.company_name || 'Company Name'
          if settings.company_address
            div= settings.company_address
          .meta
            if settings.company_phone || settings.company_email
              div
                | Mobile: #{settings.company_phone || '-'}
                if settings.company_email
                  |  | Email: #{settings.company_email}
            div
              | GSTIN - #{settings.company_gstin || settings.company_tax_number || '-'}
              if settings.company_pan
                |  | PAN - #{settings.company_pan}

      .two-col
        .col
          .section-title Invoice Details
          table.field-grid
            tr
              td.label Invoice Number
              td #{model.number}/#{model.year || ''}
            tr
              td.label Invoice Date
              td #{moment(model.date).format('DD-MMM-YY')}
            tr
              td.label Due Date
              td #{moment(model.expiredDate).format('DD-MMM-YY')}
            tr
              td.label Place of Supply
              td #{formatPlaceOfSupply(model.placeOfSupply)}
            tr
              td.label Reverse Charge
              td No
        .col
          .section-title Transporter Details
          table.field-grid
            tr
              td.label Transporter
              td.dash -
            tr
              td.label Vehicle No.
              td.dash -
            tr
              td.label Transporter Doc No.
              td.dash -
            tr
              td.label Transporter Doc Date
              td.dash -
            tr
              td.label E-Way Bill No.
              td.dash -
            tr
              td.label E-Way Bill Date
              td.dash -

      .two-col
        .col
          .section-title Billing Details
          table.field-grid
            tr
              td.label Name
              td= customer.name
            tr
              td.label GSTIN
              td= customer.gstin || '-'
            tr
              td.label Mobile
              td= customer.phone || '-'
            tr
              td.label Email
              td= customer.email || '-'
            tr
              td.label Address
              td= customer.address || '-'
        .col
          .section-title Shipping Details
          table.field-grid
            tr
              td.label Name
              td= customer.name
            tr
              td.label GSTIN
              td= customer.gstin || '-'
            tr
              td.label Mobile
              td= customer.phone || '-'
            tr
              td.label Email
              td= customer.email || '-'
            tr
              td.label Address
              td= customer.address || '-'

      .e-invoice-bar
        div IRN: -
        div Ack No.: -
        div Ack Date: -

      table.items-table
        thead
          tr
            th(style='width:4%') Sr.
            th(style='width:24%') Item Description
            th(style='width:8%') HSN/SAC
            th(style='width:6%') Qty
            th(style='width:6%') Unit
            th(style='width:10%') List Price
            th(style='width:7%') Disc.
            th(style='width:7%') Tax %
            th(style='width:12%') Amount (₹)
        tbody
          each item, index in model.items
            tr
              td.center= index + 1
              td.left
                | #{item.itemName}
                if item.description
                  span.desc-sub= item.description
              td.center= item.hsnCode || '-'
              td.center= item.quantity
              td.center Nos
              td.num ₹ #{indianAmount(item.price)}
              td.num ₹ 0.00
              td.center= item.gstRate ? item.gstRate + '%' : '0%'
              td.num ₹ #{indianAmount(item.total)}
          tr.summary-row
            td(colspan='8') Discount
            td.num ₹ #{indianAmount(model.discount || 0)}
          tr.summary-row
            td(colspan='8') Total
            td.num ₹ #{indianAmount(model.total)}

      .amount-words
        strong Amount in Words:
        |  Rs. #{amountInWords(model.total)}

      .payment-summary
        .left
          div
            strong Settled by -
            |  #{model.paymentStatus === 'paid' ? 'Paid' : model.paymentStatus === 'partially' ? 'Partial' : 'Unpaid'}
          div
            strong Invoice Balance
            |  ₹ #{indianAmount((model.total || 0) - (model.credit || 0))}
        .right
          table.tax-table
            thead
              tr
                th Type
                th Taxable
                th Tax
                th Total
            tbody
              each row in taxSummary
                tr
                  td Sale @#{row.rate}%
                  td ₹ #{indianAmount(row.taxable)}
                  td ₹ #{indianAmount(row.gst)}
                  td ₹ #{indianAmount(row.total)}
              if model.gstType === 'inter' && model.taxTotal > 0
                tr
                  td IGST
                  td
                  td ₹ #{indianAmount(model.igstTotal || model.taxTotal)}
                  td
              else if model.taxTotal > 0
                tr
                  td CGST
                  td
                  td ₹ #{indianAmount(model.cgstTotal || model.taxTotal / 2)}
                  td
                tr
                  td SGST
                  td
                  td ₹ #{indianAmount(model.sgstTotal || model.taxTotal / 2)}
                  td
              tr
                td Total Sale
                td ₹ #{indianAmount(model.subTotal)}
                td ₹ #{indianAmount(model.taxTotal)}
                td ₹ #{indianAmount(model.total)}

      .footer-grid
        .col
          .col-title Terms and Conditions
          if settings.invoice_terms_conditions
            ul.terms-list
              each line in (settings.invoice_terms_conditions || '').split(/\r?\n/)
                if line.trim()
                  li= line.trim()
          else
            ul.terms-list
              li Goods once sold will not be taken back or exchanged.
              li Interest @ 18% p.a. will be charged on overdue bills.
              li Subject to jurisdiction.
        .col
          .col-title Bank Details
          table.bank-table
            if settings.company_bank_account_number
              tr
                td.label Account Number
                td= settings.company_bank_account_number
            if settings.company_bank_name
              tr
                td.label Bank Name
                td= settings.company_bank_name
            if settings.company_bank_ifsc
              tr
                td.label IFSC
                td= settings.company_bank_ifsc
            if settings.company_bank_branch
              tr
                td.label Branch
                td= settings.company_bank_branch
            if settings.company_bank_account_name
              tr
                td.label Name
                td= settings.company_bank_account_name
            if !settings.company_bank_account_number && !settings.company_bank_name && settings.company_bank_account
              tr
                td(colspan='2')= settings.company_bank_account
            if !settings.company_bank_account_number && !settings.company_bank_name && !settings.company_bank_account
              tr
                td(colspan='2').dash Add bank details in Company Settings
        .col
          .signature-box
            div For #{settings.company_name || 'Company Name'}
            .signature-line Signature

      .page-footer
        | Invoice Created by #{settings.company_website || settings.company_name || 'Billing Software'}
