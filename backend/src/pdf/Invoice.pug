doctype html
html
  head
    link(rel="shortcut icon" type="image/png" href="/images/icons/favicon.png")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    style.
      .sheet {
        margin: 0;
        width: 100%; 
        height: 297mm;
      }

      body{
        width: 100%; 
        margin: 0;
        padding: 0;
        background: #ffffff;
        font-family: sans-serif;
        font-size: 14px;
        line-height: 1.35;
        color:#222
      }
      *, *:before, *:after {
        box-sizing: inherit;
        color:#222
      }

      .clearfix {
        display: block; }
      //- .invoice-container {
      //-   position: relative;
      //-   margin: 0 auto;
      //-   color: #001028;
      //-   background: #fff;
      //-   font-size: 10px;
      //- }
      .left{
        float:left;
      }
      .right{
        float:right;
      }
      .top-area {    
        display: block;
        width:100%;
        
      }
      alignRight :{
        text-align: right !important;
      }
      alignLeft :{
        text-align: left;
      }
      .logo {
        width: 130px;
      }
      .company-info{
        text-align: right;
        font-size: 14px;
        line-height: 1.35;
      }
      h1.invoice{
        font-size: 34px;
        color:#52008c;
        margin-top:0;
        margin-bottom: 8px;
      }
      p.strong{
        font-weight:700;
      }
      .billTo p {
        text-align: right !important;
        float:right;
        display:block;
        font-size: 14px;
        line-height: 1.35;
        width:100%;
        margin-top:0;
        margin-bottom: 8px;
        
      }

      .tableHeader{
        color:#52008c;
      }
      .clearfix {
        display: block; }
      .col {
        float:left;
      }
      .col-1 {
        width: 4.16667%; }

      .col-2 {
        width: 8.33333%; }

      .col-3 {
        width: 12.5%; }

      .col-4 {
        width: 16.66667%; }

      .col-5 {
        width: 20.83333%; }

      .col-6 {
        width: 25%; }

      .col-7 {
        width: 29.16667%; }

      .col-8 {
        width: 33.33333%; }

      .col-9 {
        width: 37.5%; }

      .col-10 {
        width: 41.66667%; }

      .col-11 {
        width: 45.83333%; }

      .col-12 {
        width: 50%; }

      .col-13 {
        width: 54.16667%; }

      .col-14 {
        width: 58.33333%; }

      .col-15 {
        width: 62.5%; }

      .col-16 {
        width: 66.66667%; }

      .col-17 {
        width: 70.83333%; }

      .col-18 {
        width: 75%; }

      .col-19 {
        width: 79.16667%; }

      .col-20 {
        width: 83.33333%; }

      .col-21 {
        width: 87.5%; }

      .col-22 {
        width: 91.66667%; }

      .col-23 {
        width: 95.83333%; }

      .col-24 {
        width: 100%; }
      .space {
        margin-top: 16px;
        margin-bottom: 18px;
        width:100%;
      }
      .top-area .number-invoice > h1 {
        font-weight: 500;
      }
      .about-invoice {
        padding: 0px 15px;
        margin-top: 10px;
        font-size: 14px;
      }
      .project-invoice {
        float: left;
        margin-bottom: 10px;
      }
      .project-invoice span {
        color: #5d6975;
        text-align: right;
        width: 52px;
        margin-right: 10px;
        display: inline-block;
        font-size: 0.8em;
      }
      .company-invoice {
        float: right;
        text-align: right;
        margin-bottom: 24px;
      }
      .project-invoice div, .company-invoice div {
        white-space: nowrap;
        margin: 5px auto;
      }
      .table-invoice {
        width: 100%;
        border-collapse: collapse;
        border-spacing: 0;
        margin-bottom: 12px;
        table-layout: fixed;
      }
      .table-invoice tr:nth-child(2n-1) td {
        background: #fcfeff;
      }
      .table-invoice th, .table-invoice td {
        text-align: center;
      }
      .table-invoice th {
        padding: 7px 6px;
        border-bottom: 1px solid #c2e0f2;
        color:#52008c;
        white-space: nowrap;
        font-weight: 700;
        font-size: 13px;
        text-align: right;
      }
      tbody{
        border-bottom: 1px solid #c2e0f2;
      }
      .table-invoice .service, .table-invoice .desc {
        text-align: left;
        width: 30%;
      }
      .table-invoice th:nth-child(2),
      .table-invoice td:nth-child(2) {
        width: 12%;
      }
      .table-invoice th:nth-child(3),
      .table-invoice td:nth-child(3) {
        width: 10%;
      }
      .table-invoice th:nth-child(4),
      .table-invoice td:nth-child(4),
      .table-invoice th:nth-child(5),
      .table-invoice td:nth-child(5),
      .table-invoice th:nth-child(6),
      .table-invoice td:nth-child(6) {
        width: 16%;
      }
      .table-invoice td {
        padding: 8px 6px;
        text-align: right;
        font-size: 13px;
        line-height: 1.3;
        word-wrap: break-word;
      }
      .table-invoice td.service, .table-invoice td.desc {
        vertical-align: top;
      }
      .table-invoice td.unit, .table-invoice td.qty, .table-invoice td.total {
        
      }
      .table-invoice td.grand {
        border-top: 1px solid #5d6975;
      }
      .service span{
        display:block;
        clear:both;
        width : 100%;
        color:#666;
        margin-top:4px;
        font-size: 12px;
      }
      .notice-invoice {
        padding: 15px;
      }
      .notice-invoice .notice {
        color: #5d6975;
        
      }
      .footer-invoice {
        margin-top: 20px;
        color: #5d6975;
        width: 100%;
        position: relative;
        padding: 12px 0;
        text-align: center;
      }
      @media print {
        html, body {
          width: 100%;
          max-width: 100%;
        }
        .sheet {
          height: auto;
        }
        header, main, table, footer {
          max-width: 100%;
        }
      }
 
  body
    
      header.clearfix
        .top-area
          img.logo.left(src=settings.public_server_file+settings.company_logo)
          .right.company-info
              p.strong #{settings.company_name}
              p #{settings.company_address}
              if settings.company_state
                p State: #{settings.company_state}
              if settings.company_gstin
                p GSTIN: #{settings.company_gstin}
              else if settings.company_tax_number
                p GSTIN: #{settings.company_tax_number}
              if settings.company_phone
                p Ph: #{settings.company_phone}
              
        .col.col-24
          .space  
        .left.col-14
            h1.invoice
              | TAX INVOICE
            div 
              .col.col-7
                p.strong #{translate('Date')} :
                p #{moment(model.date).format(dateFormat)}
              .col.col-9
                p.strong Invoice No :
                p #{model.number}/#{model.year || ""} 
              .col.col-8
                if model.placeOfSupply
                  p.strong Place of Supply :
                  p #{model.placeOfSupply}
              
        .right.col-10
            .billTo
                p.strong Bill To :
                if model.customerName
                  p #{model.customerName}
                else if model.client
                  p #{model.client.name}
                  if model.client.address
                    p #{model.client.address}
                  if model.client.state
                    p State: #{model.client.state}
                  if model.client.phone
                    p #{model.client.phone}
                else
                  p Walk-in Customer
                if model.customerGstin
                  p GSTIN: #{model.customerGstin}
                else if model.client && model.client.gstin
                  p GSTIN: #{model.client.gstin}
        .col.col-24
          .space  
      main
        table.table-invoice
          thead
            tr.tableHeader
              th.service #{translate('item')}
              th HSN
              th #{translate('Quantity')}
              th Price (excl.)
              th GST
              th #{translate('TOTAL')}
          tbody
            each item in model.items
              tr
                td.service #{item.itemName}
                  if item.description
                    span #{item.description}
                td.qty #{item.hsnCode || '-'}
                td.qty #{item.quantity}
                td.unit #{moneyFormatter({amount: item.taxableValue != null ? item.taxableValue : item.total})}
                td.unit #{moneyFormatter({amount: item.gstAmount || 0})}
                td.total #{moneyFormatter({amount:item.total})}
            tr
              td(colspan='3') Product value (excl. GST)
              td.total #{moneyFormatter({amount:model.subTotal})}
              td.total #{moneyFormatter({amount:model.taxTotal})}
              td
            if model.gstType === 'inter' && model.taxTotal > 0
              tr
                td(colspan='5') IGST
                td.total #{moneyFormatter({amount:model.igstTotal || model.taxTotal})}
            else if model.taxTotal > 0
              tr
                td(colspan='5') CGST
                td.total #{moneyFormatter({amount:model.cgstTotal || model.taxTotal / 2})}
              tr
                td(colspan='5') SGST
                td.total #{moneyFormatter({amount:model.sgstTotal || model.taxTotal / 2})}
            tr
              td.grand.total(colspan='5')  #{translate('TOTAL')}
              td.grand.total #{moneyFormatter({amount:model.total})}
        
      .col.col-24
          .space     
      footer.footer-invoice
        //- | Invoice was created on a computer and is valid without the signature and seal.
          

   
